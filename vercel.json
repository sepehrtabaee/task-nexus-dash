{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://taks-manager-phi.vercel.app/api/:path*" },
    { "source": "/health", "destination": "https://taks-manager-phi.vercel.app/health" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
